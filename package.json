{
  "name": "cityexpress-frontend-g15",
  "private": true,
  "version": "1.0.0",
  "description": "CityExpress Frontend G15 — React + Vite SPA (IIC2173 ArquiSoftware 2026-1)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
